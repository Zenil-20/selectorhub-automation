# Anchor server config — copy to .env and fill in.

ANCHOR_DB_PATH=./data/anchor.db
PORT=7821
HOST=127.0.0.1

# ============================================================
# LLM provider — pick ONE of the two paths below.
# ============================================================

# ---------- FREE PATH (recommended) -------------------------
# Groq runs Llama 3.3 70B (and friends) on their hardware,
# free tier with generous rate limits, fully OpenAI-compatible.
# Sign up at https://console.groq.com → API Keys → Create.
ANCHOR_LLM_API_KEY=
ANCHOR_LLM_BASE_URL=https://api.groq.com/openai/v1
ANCHOR_LLM_MODEL=llama-3.3-70b-versatile

# Other free OpenAI-compatible options you can drop in:
#   OpenRouter free tier — ANCHOR_LLM_BASE_URL=https://openrouter.ai/api/v1
#                          ANCHOR_LLM_MODEL=meta-llama/llama-3.1-70b-instruct:free
#   Local Ollama         — ANCHOR_LLM_BASE_URL=http://localhost:11434/v1
#                          ANCHOR_LLM_MODEL=llama3.1:70b
#                          ANCHOR_LLM_API_KEY=ollama   (any non-empty string)
#   Real OpenAI (paid)   — ANCHOR_LLM_BASE_URL=https://api.openai.com/v1
#                          ANCHOR_LLM_MODEL=gpt-4o
#                          (and add a row to server/src/llm/pricing.js)

# ---------- PAID PATH (Claude) ------------------------------
# Highest tool-calling reliability. Setting this OVERRIDES the
# free path above.
ANTHROPIC_API_KEY=
# ANCHOR_LLM_MODEL=claude-sonnet-4-6      # uncomment to override default

# ============================================================
# Cost guardrails
# ============================================================
ANCHOR_DEFAULT_DAILY_BUDGET_USD=5.00
ANCHOR_DEBUG_LLM=0
