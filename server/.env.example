# Anchor server config — copy to .env and fill in.

# ============================================================
# Database — pick ONE of the two paths.
# ============================================================

# ---------- LOCAL FILE (default for dev / on-host deploys) --
# Stored as a single SQLite file via libsql. Survives restarts
# *only* if the host has persistent storage. For Render free
# tier (ephemeral filesystem), use Turso below.
ANCHOR_DB_PATH=./data/anchor.db

# ---------- TURSO (free, persistent, cloud) -----------------
# Sign up at https://turso.tech (free tier: 9 GB / 1B reads).
#   1. `turso auth signup`  (or sign up via web)
#   2. `turso db create anchor`
#   3. `turso db show anchor --url`        → use as ANCHOR_DB_URL
#   4. `turso db tokens create anchor`     → use as ANCHOR_DB_AUTH_TOKEN
#
# When ANCHOR_DB_URL is set, ANCHOR_DB_PATH is ignored.
ANCHOR_DB_URL=
ANCHOR_DB_AUTH_TOKEN=

# ============================================================
# Server
# ============================================================
PORT=7821
HOST=127.0.0.1

# ============================================================
# LLM provider — pick ONE of the two paths.
# ============================================================

# ---------- FREE PATH (recommended) -------------------------
# Groq runs Llama 3.3 70B free, OpenAI-compatible.
ANCHOR_LLM_API_KEY=
ANCHOR_LLM_BASE_URL=https://api.groq.com/openai/v1
ANCHOR_LLM_MODEL=llama-3.3-70b-versatile

# Other free OpenAI-compatible options:
#   OpenRouter free tier — ANCHOR_LLM_BASE_URL=https://openrouter.ai/api/v1
#                          ANCHOR_LLM_MODEL=meta-llama/llama-3.1-70b-instruct:free
#   Local Ollama         — ANCHOR_LLM_BASE_URL=http://localhost:11434/v1
#                          ANCHOR_LLM_MODEL=llama3.1:70b

# ---------- PAID PATH (Claude) ------------------------------
ANTHROPIC_API_KEY=
# ANCHOR_LLM_MODEL=claude-sonnet-4-6

# ============================================================
# Hardening
# ============================================================
ANCHOR_DEFAULT_DAILY_BUDGET_USD=5.00
ANCHOR_LLM_RPM=25
ANCHOR_ALLOWED_ORIGINS=
ANCHOR_DEBUG_LLM=0
